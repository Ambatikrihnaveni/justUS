# ===========================================
# justUS Backend Environment Variables
# Copy this to .env and fill in your values
# ===========================================

# Server Port (Render will set this automatically)
PORT=5000

# MongoDB Connection String (use MongoDB Atlas for production)
# Get your connection string from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/justus?retryWrites=true&w=majority

# JWT Secret Key (IMPORTANT: Use a strong random string!)
# Generate one at: https://randomkeygen.com/
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long

# JWT Token Expiry
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS - set to your mobile app origin or leave empty for all)
FRONTEND_URL=

# Node Environment
NODE_ENV=production

# ===========================================
# Cloudinary Configuration (FREE - for file uploads)
# Sign up at: https://cloudinary.com
# Get credentials from: Dashboard > Account Details
# ===========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

